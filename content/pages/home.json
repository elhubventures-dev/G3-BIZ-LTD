  "html": "<section>\n                                \t                                    <!-- layer 2 -->\n                                        <h2>Global Strategic Business Company <br> (G3-Biz Ltd)</h2>\n                                \t                                    <!-- layer 3 -->\n                                    \t                                        <a href=\"https://g3-bizltd.com/services/\" >OUR SERVICES</a>\n                                            <a href=\"#\">\n                                                watch video\n                                            </a>\n        </section>\n\t\t                                43\n\t\t                                <h5>Years of experience</h5>\n\t\t                                22\n\t\t                                <h5>Completed projects</h5>\n\t\t                                8\n\t\t                                <h5>Drinks Marketed</h5>\n\t\t                                40\n\t\t                                <h5>No of Awards won</h5>\n\t\t                                19\n\t\t                                <h5>Years of Operation</h5>\n                        \t                            <p>Who Are We, G3-Biz?</p>\n                                                                                    <h2>OUR VISION</h2>\n                                                                                    <p><strong>Establish G3-Biz Ltd as the most reputable enterprise in Cameroon in terms of TRUST, EXPANSION, VALUE CREATION/SHARING</strong> <br> <br>\n- Giving customers Good value for their investment <br>\n- Creating occasions that enhance social interaction and pleasure <br>\n- Offering trustful partnership to suppliers <br>\n- Providing a better life to shareholders and employees </p>\n                                            <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/09/2.png\" alt=\"\">\n                                       <a href=\"https://g3-bizltd.com/product/guinness\"><h4>Guinness</h4></a>\n                                       <p>World-famous Irish stout, known for its deep, dark color and rich, creamy head, and one of the most iconic beers globally, recognized for its smooth texture and distinct flavor. </p>\n                                       01\n                        \t                        \t\t\t\t\t\t\t\t                            <!-- Start feature column  -->\n                                            <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/09/7.png\" alt=\"\">\n                                       <a href=\"https://g3-bizltd.com/product/guinnesssmooth\"><h4>Guinness Smooth</h4></a>\n                                       <p>A lighter, more approachable version of the original Guinness stout. It retains the signature creamy head but has a milder flavor profile with less bitterness, making it easier to drink for those new to stout beers. </p>\n                                       02\n                                            <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/09/8.png\" alt=\"\">\n                                       <a href=\"https://g3-bizltd.com/product/origin\"><h4>Origin</h4></a>\n                                       <p>A fruity and refreshing alcoholic beverage made from a blend of natural fruit flavors. It's popular for its vibrant taste and lower alcohol content, offering a sweet and tangy drinking experience. It's ideal for casual, social settings and appeals to those who enjoy light, fruity drinks. </p>\n                                       03\n            <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/09/bg-icon.png\" alt=\"\">\n                    <!-- Start Column Start -->\n                                <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/08/WhatsApp-Image-2024-08-20-at-19.18.08-2-e1725534524931.jpeg\" alt=\"\">\n                                \t                            <p>About G3-Biz Ltd</p>\n\t                            \t                            \t                            <h2>Culture: “Success from Trustful Relationships”</h2>\n\t                            \t                            \t                            <p>Offering managerial trainings and consultancy, and internship opportunities to learners. </p>\n                                    4\n                                    Strategic Pillars\n                                    <ul>\n                                    \t                                        <li>Human Resource optimization</li>\n                                    \t                                        <li>Exponential Volume Growth</li>\n                                    \t                                        <li>Market Share Growth</li>\n                                    \t                                        <li>Investing with wisdom on assets</li>\n                                    \t                                    </ul>\n                                        Friendly <br> Team\n                                        Goal <br> Achievement\n                    <!-- End Column -->\n                                \t                            <p>Objectives</p>\n\t                            \t                            \t                            <h2>Our main objectives at G3-Biz Ltd are:</h2>\n                                                        <!-- about single -->\n                               \t<a href=\"#\"></a>\n                                    <h4>Primary and secondary distribution of finished products</h4>\n                                    <p></p>\n                        \t                            <!-- about single -->\n                               \t<a href=\"#\"></a>\n                                    <h4>Management training/Consultancy</h4>\n                                    <p></p>\n                        \t                            <!-- about single -->\n                               \t<a href=\"#\"></a>\n                                    <h4>Offering internship training opportunities</h4>\n                                    <p></p>\n                                                                <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/08/WhatsApp-Image-2024-08-20-at-19.18.08-3.jpeg\" alt=\"\">\n                                \t                            <p>Our services</p>\n\t                            \t                            \t                            <h2>At G3-Biz, we don't just distribute Guinness products</h2>\n\t                            \t                            \t                            <p>we empower businesses to succeed. Here's how: </p>\n                                <a href=\"https://g3-bizltd.com/services/\">More Services </a>\n                                        <!-- single-service end-->\n                                    <img src=\"https://shtheme.com/demosd/wintem/wp-content/uploads/2023/07/p1.png\" alt=\"\">\n                                    <h4><a href=\"https://g3-bizltd.com/services/reputable-customer-of-gcsa/\">Reputable Customer of GCSA</a></h4>\n                                    <p>G3-Biz is the main distributor of GCSA products in Limbe Cameroon. Consultation services are additional support that G3-Biz offers to its customers free of charge, ensuring you get the most out of your partnership with us...</p>\n                                \t                            <p>Team Spotlight:</p>\n\t                            \t                            \t                            <h2>The Dream Team Behind Our Success</h2>\n                                <a href=\"https://g3-bizltd.com/teams\">More Team Members </a>\n                                        <!-- Single team member -->\n                                    <img src=\"https://g3-bizltd.com/wp-content/uploads/2024/09/44444444444444.png\" alt=\"\">\n            